    <script type="text/javascript">
        // Wait for ExtJS to fully load, then inject tree icons
        window.addEventListener('load', function() {
            setTimeout(function() {
                // Use local GIFs for all icons
                var folderIcon = 'resources/themes/images/default/tree/folder.gif';
                var fileIcon = 'resources/themes/images/default/tree/leaf.gif';
                var plusIcon = 'resources/themes/images/default/tree/elbow-plus.gif';
                var minusIcon = 'resources/themes/images/default/tree/elbow-minus.gif';
                var elbowIcon = 'resources/themes/images/default/tree/elbow.gif';
                var elbowLineIcon = 'resources/themes/images/default/tree/elbow-line.gif';
                var elbowEmptyIcon = 'resources/themes/images/default/tree/elbow-empty.gif';

                function updateTreeIcons() {
                    // Folder icons
                    document.querySelectorAll('img.x-tree-icon-parent').forEach(function(img) {
                        img.src = folderIcon;
                        img.style.opacity = '1';
                        img.style.width = '16px';
                        img.style.height = '16px';
                    });
                    // File/leaf icons
                    document.querySelectorAll('img.x-tree-icon-leaf').forEach(function(img) {
                        img.src = fileIcon;
                        img.style.opacity = '1';
                        img.style.width = '16px';
                        img.style.height = '16px';
                    });
                    // Expand/collapse icons
                    document.querySelectorAll('img.x-tree-elbow-plus, img.x-tree-elbow-end-plus').forEach(function(img) {
                        img.src = plusIcon;
                        img.style.width = '18px';
                        img.style.height = '18px';
                    });
                    document.querySelectorAll('img.x-tree-elbow-minus, img.x-tree-elbow-end-minus').forEach(function(img) {
                        img.src = minusIcon;
                        img.style.width = '18px';
                        img.style.height = '18px';
                    });
                    // Elbow/line/empty
                    document.querySelectorAll('img.x-tree-elbow, img.x-tree-elbow-end').forEach(function(img) {
                        img.src = elbowIcon;
                        img.style.width = '18px';
                        img.style.height = '18px';
                    });
                    document.querySelectorAll('img.x-tree-elbow-line').forEach(function(img) {
                        img.src = elbowLineIcon;
                        img.style.width = '18px';
                        img.style.height = '18px';
                    });
                    document.querySelectorAll('img.x-tree-elbow-empty').forEach(function(img) {
                        img.src = elbowEmptyIcon;
                        img.style.width = '18px';
                        img.style.height = '18px';
                    });
                }
                updateTreeIcons();
                // Watch for DOM changes and update icons
                var observer = new MutationObserver(function() { updateTreeIcons(); });
                var treePanel = document.querySelector('.x-tree-panel');
                if (treePanel) {
                    observer.observe(treePanel, {
                        childList: true,
                        subtree: true,
                        attributes: true,
                        attributeFilter: ['class']
                    });
                }
            }, 1000);
        });
    </script>
