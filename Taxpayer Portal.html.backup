    <title>Taxpayer Portal</title>
    <link rel="stylesheet" href="./Taxpayer Portal_files/all.css" id="allcss">
    <style>
        .tree {
            font-size: 14px;
            font-family: Arial, sans-serif;
            padding: 0 0 0 0;
            margin: 0;
        }
        .tree-title {
            font-weight: bold;
            color: #2a4b8d;
            background: #e6eef8;
            padding: 6px 10px;
            border-bottom: 1px solid #b5b8c8;
        }
        .tree ul {
            list-style: none;
            padding-left: 18px;
            margin: 0;
        }
        .tree li {
            margin: 2px 0;
            cursor: pointer;
            white-space: nowrap;
            line-height: 20px;
            position: relative;
        }
        .tree .folder {
            font-weight: bold;
        }
        .tree .icon {
            width: 16px;
            display: inline-block;
            vertical-align: middle;
            filter: sepia(100%) saturate(300%) brightness(100%) hue-rotate(10deg);
        }
        .tree .toggle {
            width: 16px;
            display: inline-block;
            vertical-align: middle;
            cursor: pointer;
            color: #2a4b8d;
            font-weight: bold;
            user-select: none;
        }
        .tree .file {
            font-weight: normal;
        }
    </style>
    <script>
        // Complete tree data - Integrated Tax System is the main root
        const treeData = [
            {
                label: "Integrated Tax System",
                children: [
                    {
                        label: "General",
                        children: [
                            { label: "Taxpayer Login" },
                            { label: "Create Taxpayer Login" },
                            { label: "Forgot Password" },
                            { label: "Drug Manufacturer's Login" },
                            { label: "Payment Voucher Search" }
                        ]
                    },
                    {
                        label: "Registration(PAN,VAT,EXCISE)",
                        children: [
                            { label: "Application For Registration" },
                            { label: "Registration Log In" }
                        ]
                    },
                    {
                        label: "VAT",
                        children: [
                            { label: "VAT Return Entry" },
                            { label: "VAT Return Login" },
                            { label: "VAT Close Of Business Entry" },
                            { label: "VAT Close Of Business Login" },
                            { label: "Help" }
                        ]
                    },
                    {
                        label: "Non-Resident Person (DST/VAT)",
                        children: [
                            { label: "Application For DST Registration" },
                            { label: "Registration Log In" },
                            { label: "VAT Return Entry" },
                            { label: "VAT Return Login" },
                            { label: "DST Return Entry" },
                            { label: "DST VAT Return Entry" }
                        ]
                    },
                    {
                        label: "Non-Resident Airlines",
                        children: [
                            { label: "Application For Registration" },
                            { label: "Registration Log In" },
                            { label: "NRA VAT Return Entry" },
                            { label: "NRA VAT Return Login" }
                        ]
                    },
                    {
                        label: "Estimated Return",
                        children: [
                            { label: "Estimated Return Entry" },
                            { label: "Estimated Return D02 Entry" }
                        ]
                    },
                    {
                        label: "Income Tax",
                        children: [
                            { label: "D-01 Return Entry" },
                            { label: "D-02 Return Entry" },
                            { label: "D-03 Return Entry" },
                            { label: "D-04 Return Entry" },
                            { label: "Jeopardy Assessment" },
                            { label: "Change of Control" },
                            { label: "Close of Business D-01" },
                            { label: "Close of Business D-02" },
                            { label: "Close of Business D-03" },
                            { label: "Tax Return Login" },
                            { label: "Help" }
                        ]
                    },
                    {
                        label: "Excise",
                        children: [
                            { label: "Return Entry" },
                            { label: "Excise Return Login" },
                            { label: "Close Of Business Entry" },
                            { label: "Excise Close Of Business Login" },
                            { label: "Self Renew Permit" },
                            { label: "New Permit" },
                            { label: "Manufacturer's Login" },
                            { label: "Brand Registration" },
                            { label: "Brand Registration Login" }
                        ]
                    },
                    {
                        label: "E-TDS",
                        children: [
                            { label: "E-TDS" }
                        ]
                    },
                    {
                        label: "Diplomatic Refund",
                        children: [
                            { label: "Diplomatic Refund Login" }
                        ]
                    },
                    {
                        label: "Health Tax",
                        children: [
                            { label: "Returns Entry" },
                            { label: "Returns Login" },
                            { label: "Close of Business Entry" },
                            { label: "Close of Business Login" }
                        ]
                    },
                    {
                        label: "Education Tax",
                        children: [
                            { label: "Returns Entry" },
                            { label: "Returns Login" },
                            { label: "Close Of Business Entry" },
                            { label: "Close Of Business Login" }
                        ]
                    },
                    {
                        label: "Electronic Billing",
                        children: [
                            { label: "Electronic Billing Software Listing" },
                            { label: "Software Listing Login" },
                            { label: "Electronic Billing User Permission" },
                            { label: "User Permission Login" }
                        ]
                    },
                    {
                        label: "Education Service Fee",
                        children: []
                    },
                    {
                        label: "Foreign Employment Service Fee",
                        children: []
                    },
                    {
                        label: "Foreign Tourism Fee",
                        children: []
                    },
                    {
                        label: "Other Offices",
                        children: [
                            { label: "Log In/Out" }
                        ]
                    }
                ]
            }
        ];
        // Use folder/file icons similar to the original
        const folderClosed = '📁';
        const folderOpen = '📂';
        const fileIcon = '📄';
        const plusIcon = '[+]';
        const minusIcon = '[-]';

        function createTreeNode(node) {
            const li = document.createElement('li');
            if (node.children && node.children.length > 0) {
                li.innerHTML = '<span class="toggle">' + plusIcon + '</span> <span class="icon">' + folderClosed + '</span> <span class="folder">' + node.label + '</span>';
                const ul = document.createElement('ul');
                ul.style.display = 'none';
                node.children.forEach(child => {
                    ul.appendChild(createTreeNode(child));
                });
                li.appendChild(ul);
                const toggle = li.querySelector('.toggle');
                const icon = li.querySelector('.icon');
                const folder = li.querySelector('.folder');
                function toggleFolder(e) {
                    e.stopPropagation();
                    if (ul.style.display === 'none') {
                        ul.style.display = 'block';
                        toggle.textContent = minusIcon;
                        icon.textContent = folderOpen;
                    } else {
                        ul.style.display = 'none';
                        toggle.textContent = plusIcon;
                        icon.textContent = folderClosed;
                    }
                }
                toggle.onclick = toggleFolder;
                icon.onclick = toggleFolder;
                folder.onclick = toggleFolder;
            } else {
                li.innerHTML = '<span class="icon">' + fileIcon + '</span> <span class="file">' + node.label + '</span>';
            }
            return li;
        }

        window.addEventListener('DOMContentLoaded', function() {
            const treeColBody = document.getElementById('treeCol-body');
            if (treeColBody) {
                treeColBody.innerHTML = '';
                const treeDiv = document.createElement('div');
                treeDiv.className = 'tree';
                const titleDiv = document.createElement('div');
                titleDiv.className = 'tree-title';
                titleDiv.textContent = 'Online E-Services';
                treeDiv.appendChild(titleDiv);
                const ul = document.createElement('ul');
                treeData.forEach(node => {
                    ul.appendChild(createTreeNode(node));
                });
                treeDiv.appendChild(ul);
                treeColBody.appendChild(treeDiv);
            }
        });
    </script>

